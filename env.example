MCP_GATEWAY_ADDR=127.0.0.1:8787
MCP_GATEWAY_PUBLIC_BASE_URL=https://mcp.example.com
MCP_GATEWAY_DATABASE=/data/mcp-gateway.db
# Bare tokens get all tools. Scoped tokens use token=scope1|scope2.
MCP_GATEWAY_API_KEYS=replace-with-long-random-token,replace-with-search-token=tool:grok_search
MCP_GATEWAY_ALLOWED_ORIGINS=https://agents.example.com,https://mcp.example.com
MCP_GATEWAY_AUTHORIZATION_SERVERS=https://auth.example.com
MCP_GATEWAY_PROTECT_METRICS=true
MCP_GATEWAY_MAX_CONCURRENCY=8
MCP_GATEWAY_RATE_LIMIT_PER_MIN=60
MCP_GATEWAY_MAX_BODY_BYTES=1048576
MCP_GATEWAY_UPSTREAM_TIMEOUT=60s
MCP_GATEWAY_CACHE_TTL=10m
MCP_GATEWAY_AUDIT_RETENTION=720h
MCP_GATEWAY_AUDIT_REMOTE_ADDR=false
MCP_GATEWAY_CLEANUP_INTERVAL=1h
MCP_GATEWAY_LOG_LEVEL=info

GROK_ENABLED=true
GROK_API_URL=https://api.example.com/v1/chat/completions
GROK_API_KEY=replace-with-provider-key
GROK_DEFAULT_MODEL=grok-4.3-fast
GROK_FALLBACK_MODELS=grok-4.3,grok-4.2-fast
GROK_MAX_RETRIES=2
GROK_MAX_QUERY_BYTES=32768
GROK_MAX_RESPONSE_BYTES=4194304
